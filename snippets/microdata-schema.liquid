{%- comment -%}
This snippet structures the micro-data using JSON-LD specification. Please note that for Product especially,
the schema often changes. We try to output as much info as possible, but Google may add new requirements over time,
or change the format of some info
{%- endcomment -%}

{%- if request.page_type == 'product' -%}
  {%- assign days_product_price_valid_until = 10 | times: 86400 -%}

  {%- comment -%}
    Compared downcased on purpose: shop.name is "Vcollect" while the own-brand
    products carry the vendor "VCOLLECT" (verified on the Admin API, 21/07/2026).
    A strict comparison silently never matches.
  {%- endcomment -%}
  {%- assign house_brand = shop.name | downcase -%}
  {%- assign product_brand = product.vendor | downcase -%}

  {%- comment -%}
    Custom (not Impact): Google's merchant-listing report asks for a return
    policy on every offer. The store ships only to EU countries (BE, DE, ES, FR,
    IT, PT, read from shop.shipsToCountries on the Admin API, 23/07/2026), where
    the 14-day right of withdrawal applies uniformly, so a single policy is exact
    for the whole catalogue. The customer bears the return postage, confirmed by
    Lucas on 23/07/2026, hence ReturnFeesCustomerResponsibility (the customer is
    responsible for the actual cost) rather than a fixed ReturnShippingFees
    amount we do not have. If the published refund page ever changes (free
    returns, longer window, new market), update the fields below so the markup
    can never contradict it.
  {%- endcomment -%}
  {%- capture merchant_return_policy -%}
    "hasMerchantReturnPolicy": {
      "@type": "MerchantReturnPolicy",
      "applicableCountry": ["BE", "DE", "ES", "FR", "IT", "PT"],
      "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
      "merchantReturnDays": 14,
      "returnMethod": "https://schema.org/ReturnByMail",
      "returnFees": "https://schema.org/ReturnFeesCustomerResponsibility"
    }
  {%- endcapture -%}

  {%- comment -%}
    Custom (not Impact): shipping rates + delay per destination, read from the
    store's delivery profile "Profil général" on the Admin API (23/07/2026). The
    carrier rates are weight-tiered, but Google wants one rate per product, so we
    emit the entry tier (lightest parcel = one sealed item, exact for today's
    unweighed catalogue and single-item orders). Per zone, the cheapest option:
    FR 3.90 / BE 5.90 / ES-PT 7.90 / IT 7.90 (Mondial Relay point-relais), DE
    11.50 (home only, no relay in that zone). transitTime 2-3 days comes straight
    from the method names ("48-72h"). handlingTime 0-2 days comes from the
    published shipping policy ("Les envois sont effectués en moins de 48h",
    read on the Admin API, 24/07/2026); if that promise changes, change it here
    too so the markup keeps matching the policy page.

    All rates are EUR: shop.shipsToCountries is the 6 EU countries below, none in
    a non-EUR market. If a rate, a delay or a shipping country changes in the
    admin, update the entries here so the markup keeps telling the truth.
  {%- endcomment -%}
  {%- capture shipping_details -%}
    "shippingDetails": [
      {%- assign shipping_countries = "FR,3.90|BE,5.90|ES,7.90|PT,7.90|IT,7.90|DE,11.50" | split: "|" -%}
      {%- for entry in shipping_countries -%}
        {%- assign parts = entry | split: "," -%}
        {
          "@type": "OfferShippingDetails",
          "shippingRate": {
            "@type": "MonetaryAmount",
            "value": {{ parts[1] | json }},
            "currency": "EUR"
          },
          "shippingDestination": {
            "@type": "DefinedRegion",
            "addressCountry": {{ parts[0] | json }}
          },
          "deliveryTime": {
            "@type": "ShippingDeliveryTime",
            "handlingTime": {
              "@type": "QuantitativeValue",
              "minValue": 0,
              "maxValue": 2,
              "unitCode": "DAY"
            },
            "transitTime": {
              "@type": "QuantitativeValue",
              "minValue": 2,
              "maxValue": 3,
              "unitCode": "DAY"
            }
          }
        }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]
  {%- endcapture -%}

  {%- capture main_entity_microdata -%}
    {%- assign is_valid_global_gtin_length = false -%}

    {%- if product.selected_or_first_available_variant.barcode != blank -%}
      {%- assign gtin_string_length = product.selected_or_first_available_variant.barcode | size -%}

      {%- if gtin_string_length == 8 or gtin_string_length == 12 or gtin_string_length == 13 or gtin_string_length == 14 -%}
        {%- assign is_valid_global_gtin_length = true -%}
      {%- endif -%}
    {%- endif -%}

    "@type": "Product",
    "productID": {{ product.id | json }},
    "offers": [
      {%- for variant in product.variants -%}
        {%- assign is_valid_gtin_length = false -%}

        {%- if variant.barcode != blank -%}
          {%- assign gtin_string_length = variant.barcode | size -%}

          {%- if gtin_string_length == 8 or gtin_string_length == 12 or gtin_string_length == 13 or gtin_string_length == 14 -%}
            {%- assign is_valid_gtin_length = true -%}
          {%- endif -%}
        {%- endif -%}

        {
          "@type": "Offer",
          "name": {% if product.has_only_default_variant %}{{ product.title | json }}{% else %}{{ variant.title | json }}{% endif %},
          "availability": {%- if variant.available -%}"https://schema.org/InStock"{%- elsif variant.incoming -%}"https://schema.org/BackOrder"{% else %}"https://schema.org/OutOfStock"{%- endif -%},
          {%- comment -%}
            Custom (not Impact): itemCondition is required by Google for merchant
            listings, and Impact emitted none.

            Every product of the catalogue is sealed and new. There is no metafield
            holding the condition today: referentiel-catalogue.md describes a
            vcollect.etat_boite, but the definition was never created, verified
            against the Admin API on 21/07/2026 (the vcollect namespace has
            etat_carte, unused, and no etat_boite). shopify.condition exists but is
            filled on 7 products out of 147.

            So this is a flat NewCondition, which is exact for the whole catalogue
            today. The day damaged sealed goods are sold, read the condition here
            rather than leaving this line to lie.
          {%- endcomment -%}
          "itemCondition": "https://schema.org/NewCondition",
          "price": {{ variant.price | divided_by: 100.0 | json }},
          "priceCurrency": {{ cart.currency.iso_code | json }},
          "priceValidUntil": "{{ 'now' | date: '%s' | plus: days_product_price_valid_until | date: '%Y-%m-%d' }}",
          {%- comment -%}
            Custom (not Impact): pairs with priceValidUntil to bound the offer's
            validity. published_at is the real date the product went on sale, so
            the price has been valid since then, verifiable per product.
          {%- endcomment -%}
          "validFrom": "{{ product.published_at | date: '%Y-%m-%d' }}",
          {%- if variant.sku != blank -%}
            "sku": {{ variant.sku | json }},
          {%- endif -%}
          {%- comment -%}
            Custom (not Impact): Impact only ever derived gtin and mpn from the
            barcode, so a variant with no barcode carried no identifier at all.
            Google asks for brand + mpn on products that legitimately have no
            manufacturer GTIN, which is the case of the VCOLLECT own-brand
            accessories: 14 fiches, 0 barcode, 11 with a house sku (Admin API,
            21/07/2026). brand is already emitted below from product.vendor, so
            the sku is the missing half of the pair.

            Falling back to the sku is only correct because VCOLLECT is itself
            the brand on these products, which makes its part number the
            manufacturer part number. Never do this for resold goods: there the
            mpn belongs to the real manufacturer and the sku is internal.
          {%- endcomment -%}
          {%- if variant.barcode != blank -%}
            {%- if is_valid_gtin_length -%}
              "gtin": {{ variant.barcode | json }},
            {%- else -%}
              "mpn": {{ variant.barcode | json }},
            {%- endif -%}
          {%- elsif variant.sku != blank and product_brand == house_brand -%}
            "mpn": {{ variant.sku | json }},
          {%- endif -%}
          {{ merchant_return_policy }},
          {{ shipping_details }},
          "url": "{{ shop.url }}{{ product.url }}?variant={{ variant.id }}"
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ],
    {%- if product.metafields.reviews.rating.value != blank and product.metafields.reviews.rating_count.value > 0 -%}
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "{{ product.metafields.reviews.rating.value }}",
        "reviewCount": "{{ product.metafields.reviews.rating_count.value }}",
        "worstRating": "{{ product.metafields.reviews.rating.value.scale_min }}",
        "bestRating": "{{ product.metafields.reviews.rating.value.scale_max }}"
      },
    {%- endif -%}
    "brand": {
      "@type": "Brand",
      "name": {{ product.vendor | json }}
    },
    "name": {{ product.title | json }},
    "description": {{ product.description | strip_html | json }},
    "category": {{ product.type | json }},
    "url": "{{ shop.url }}{{ product.url }}",
    {%- comment -%}
      Impact core override: Impact emitted this sku unconditionally, so a product
      without one rendered `"sku": null`, which invalidates the whole Product block
      for Google. It was firing on 138 product pages out of 138 when the fix landed.
      Since then house skus have been created: 25 pages sampled on production on
      21/07/2026 showed 20 with no sku key at all and 5 carrying a real value.
    {%- endcomment -%}
    {%- if product.selected_or_first_available_variant.sku != blank -%}
      "sku": {{ product.selected_or_first_available_variant.sku | json }},
    {%- endif -%}
    {%- comment -%}
      Same brand + mpn fallback as on the Offer above, kept in sync so the
      product-level identifier never contradicts the offer-level one.
    {%- endcomment -%}
    {%- if product.selected_or_first_available_variant.barcode != blank -%}
      {%- if is_valid_global_gtin_length -%}
        "gtin": {{ product.selected_or_first_available_variant.barcode | json }},
      {%- else -%}
        "mpn": {{ product.selected_or_first_available_variant.barcode | json }},
      {%- endif -%}
    {%- elsif product.selected_or_first_available_variant.sku != blank and product_brand == house_brand -%}
      "mpn": {{ product.selected_or_first_available_variant.sku | json }},
    {%- endif -%}
    {%- comment -%}
      Impact core override: 0 is truthy in Liquid, so an unweighed product emitted
      "value": 0.0. Every product of the catalogue is unweighed today, so the block
      was pure noise. Compare against 0 instead of testing truthiness.
    {%- endcomment -%}
    {%- if product.selected_or_first_available_variant.weight > 0 -%}
      "weight": {
        "@type": "QuantitativeValue",
        "unitCode": {{ product.selected_or_first_available_variant.weight_unit | json }},
        "value": {{ product.selected_or_first_available_variant.weight_in_unit | json }}
      },
    {%- endif -%}
    {%- comment -%}
      Impact core override: Impact sent a single ImageObject built from page_image,
      with hardcoded 1024x1024 dimensions that are wrong whenever the source image
      is not square. Google asks for the product images as a list of URLs, and uses
      several of them when they are offered, so send the whole gallery.

      Fix of 21/07/2026: the first version of this override appended page_image
      after the loop, unconditionally. page_image is the featured image, which is
      already part of product.media, so every product shipped its main visual
      twice. Measured on production: 137 fiches out of 146 carried a duplicate.
      page_image is now only the fallback for a product that has no image media
      at all, and the separator is driven by forloop so the array stays valid.
    {%- endcomment -%}
    {%- assign gallery = product.media | where: 'media_type', 'image' -%}
    "image": [
      {%- if gallery.size > 0 -%}
        {%- for media in gallery limit: 6 -%}
          {{ media | image_url: width: 1600 | prepend: 'https:' | json }}
          {%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      {%- elsif page_image != blank -%}
        {{ page_image | image_url: width: 1600 | prepend: 'https:' | json }}
      {%- endif -%}
    ]
  {%- endcapture -%}
{%- elsif request.page_type == 'collection' -%}
  {%- comment -%}
    Custom (not Impact): Impact ships no ItemList at all, so the 41 collection pages
    told Google nothing about what they list. ItemList is what makes a category page
    eligible for the carousel treatment. Capped at the first 24 products, which is
    the default page size, so page 2 lists its own products rather than repeating.
  {%- endcomment -%}
  {%- if collection.products_count > 0 -%}
    {%- capture main_entity_microdata -%}
      "@type": "ItemList",
      "name": {{ collection.title | json }},
      "numberOfItems": {{ collection.products_count | json }},
      "itemListElement": [
        {%- for product in collection.products limit: 24 -%}
          {
            "@type": "ListItem",
            "position": {{ forloop.index }},
            "name": {{ product.title | json }},
            "url": {{ shop.url | append: product.url | json }}
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    {%- endcapture -%}
  {%- endif -%}
{%- elsif request.page_type == 'article' -%}
  {%- capture main_entity_microdata -%}
    "@type": "BlogPosting",
    "mainEntityOfPage": "{{ article.url }}",
    "articleSection": {{ blog.title | json }},
    "keywords": "{{ article.tags | join: ', ' }}",
    "headline": {{ article.title | json }},
    "description": {{ article.excerpt_or_content | strip_html | truncatewords: 25 | json }},
    "dateCreated": "{{ article.created_at | date: '%Y-%m-%dT%T' }}",
    "datePublished": "{{ article.published_at | date: '%Y-%m-%dT%T' }}",
    "dateModified": "{{ article.updated_at | date: '%Y-%m-%dT%T' }}",
    "image": {
      "@type": "ImageObject",
      "url": "https:{{ page_image | image_url: width: 1024 }}",
      "image": "https:{{ page_image | image_url: width: 1024 }}",
      "name": {{ page_image.alt | json }},
      "width": "1024",
      "height": "1024"
    },
    "author": {
      "@type": "Person",
      "name": "{{ article.user.first_name | escape }} {{ article.user.last_name | escape }}",
      "givenName": {{ article.user.first_name | json }},
      "familyName": {{ article.user.last_name | json }}
    },
    "publisher": {
      "@type": "Organization",
      "name": {{ shop.name | json }}
    },
    "commentCount": {{ article.comments_count }},
    "comment": [
      {%- for comment in article.comments limit: 5 -%}
        {
          "@type": "Comment",
          "author": {{ comment.author | json }},
          "datePublished": "{{ comment.created_at | date: '%Y-%m-%dT%T' }}",
          "text": {{ comment.content | json }}
        }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]
  {%- endcapture -%}
{%- endif -%}

{%- comment -%}
Impact core override: the BreadcrumbList that used to be built here was removed. It is now emitted by
snippets/breadcrumb.liquid, which also renders the visible trail, so the two can never state different paths. That
version adds the parent category read from the main menu, which this one had no way to know, and it fixed an error
where an article listed the blog title twice instead of the article title.

If an Impact update brings this block back, delete it again: two BreadcrumbList on the same page compete.
{%- endcomment -%}

{% if main_entity_microdata != blank %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    {{ main_entity_microdata }}
  }
  </script>
{% endif %}


{%- if request.page_type == 'index' -%}
  {%- assign potential_action_target = request.origin | append: routes.search_url | append: "?q={search_term_string}" -%}

  <script type="application/ld+json">
  [
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": {{ shop.name | json }},
      "url": {{ shop.url | append: page.url | json }},
      "potentialAction": {
        "@type": "SearchAction",
        "target": {{ potential_action_target | json }},
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": {{ shop.name | json }},
      {%- if shop.brand.logo -%}
        "logo": {{ shop.brand.logo | image_url: width: shop.brand.logo.width | prepend: "https:" | json }},
      {%- endif -%}
      {%- if shop.brand.short_description -%}
        "description": {{ shop.brand.short_description | json }},
      {%- endif -%}
      {%- if shop.brand.slogan -%}
        "slogan": {{ shop.brand.slogan | json }},
      {%- endif -%}
      {%- if shop.brand.metafields.social_links.size > 0 -%}
        "sameAs": [
          {%- for social_link in shop.brand.metafields.social_links -%}
            {{- social_link.last.value | json -}}{%- unless forloop.last -%},{%- endunless -%}
          {%- endfor -%}
        ],
      {%- endif -%}
      "url": {{ shop.url | append: page.url | json }}
    }
  ]
  </script>
{%- endif -%}