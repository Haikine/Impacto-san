    },
    {
      "type": "color",
      "id": "background",
      "label": "Fond",
      "default": "#1a1a1a"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Dégradé de fond",
      "default": "linear-gradient(140deg, rgba(26, 26, 26, 1), rgba(0, 58, 112, 1) 100%)"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Texte",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Voile sur l'image",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Opacité du voile",
      "default": 40
    },
    {
      "type": "color",
      "id": "countdown_background",
      "label": "Fond des compteurs",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "countdown_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Opacité des compteurs",
      "default": 15
    },
    {
      "type": "color",
      "id": "countdown_text_color",
      "label": "Texte des compteurs",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Fond du bouton",
      "default": "#0043b5"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Texte du bouton",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Bannière compte à rebours"
    }
  ]
}
{% endschema %}
